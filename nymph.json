{
  "manifest_version": 1,
  "id": "brain",
  "name": "Brain",
  "short_name": "BR",
  "version": "0.1.5",
  "description": "Local assistant, llama-server, Open WebUI, and MCP orchestration stack packaged as an installable Nymph module.",
  "category": "service",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/brain.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/brain.git",
    "ref": "main"
  },
  "install": {
    "root": "$HOME/Nymphs-Brain",
    "entrypoint": "scripts/install_brain.sh",
    "version_marker": "$HOME/Nymphs-Brain/.nymph-module-version",
    "installed_markers": [
      "$HOME/Nymphs-Brain/.nymph-module-version",
      "$HOME/Nymphs-Brain/bin/brain-status"
    ]
  },
  "runtime": {
    "services": [
      {
        "id": "llama-server",
        "host": "127.0.0.1",
        "port": 8000,
        "health_url": "http://127.0.0.1:8000/v1/models"
      },
      {
        "id": "open-webui",
        "host": "127.0.0.1",
        "port": 8081,
        "url": "http://127.0.0.1:8081"
      },
      {
        "id": "mcp",
        "host": "127.0.0.1",
        "port": 8100,
        "status_url": "http://127.0.0.1:8100/status"
      },
      {
        "id": "mcpo",
        "host": "127.0.0.1",
        "port": 8099,
        "url": "http://127.0.0.1:8099"
      }
    ]
  },
  "entrypoints": {
    "install": "scripts/install_brain.sh",
    "update": "scripts/brain_update.sh",
    "status": "scripts/brain_status.sh",
    "start": "scripts/brain_start.sh",
    "stop": "scripts/brain_stop.sh",
    "webui": "scripts/brain_webui.sh",
    "open": "scripts/brain_open.sh",
    "manage_models": "scripts/brain_manage_models.sh",
    "llm_dir": "scripts/brain_llm_dir.sh",
    "apply_key": "scripts/brain_apply_key.sh",
    "logs": "scripts/brain_logs.sh",
    "uninstall": "scripts/brain_uninstall.sh"
  },
  "ui": {
    "sort_order": 10,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_url",
      "title": "Open WebUI",
      "url": "http://localhost:8081",
      "requires_running": true,
      "start_action": "webui"
    },
    "manager_action_groups": [
      {
        "id": "openrouter_key",
        "title": "OpenRouter",
        "layout": "compact",
        "entrypoint": "apply_key",
        "result": "show_output",
        "visibility": "installed",
        "description": "Optional. Enables the Brain llm-wrapper tool bridge.",
        "fields": [
          {
            "name": "openrouter_api_key",
            "type": "secret",
            "label": "OpenRouter key",
            "secret_id": "openrouter.api_key",
            "env": "OPENROUTER_API_KEY",
            "optional": true
          }
        ],
        "submit": {
          "label": "Apply Key"
        }
      }
    ],
    "manager_actions": [
      {
        "id": "manage_models",
        "label": "Manage Models",
        "entrypoint": "manage_models",
        "result": "open_terminal"
      },
      {
        "id": "llm_dir",
        "label": "LLM Dir",
        "entrypoint": "llm_dir",
        "result": "open_directory"
      },
      {
        "id": "start",
        "label": "Start Brain",
        "entrypoint": "start",
        "result": "show_output"
      },
      {
        "id": "stop",
        "label": "Stop Brain",
        "entrypoint": "stop",
        "result": "show_output"
      },
      {
        "id": "webui",
        "label": "Open WebUI",
        "entrypoint": "webui",
        "result": "open_in_manager"
      },
      {
        "id": "browser",
        "label": "Browser",
        "entrypoint": "webui",
        "result": "open_external_browser"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "show_output"
      }
    ]
  },
  "uninstall": {
    "supports_purge": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "preserve_by_default": [
      "models",
      "open-webui-data",
      "mcp",
      "secrets",
      "logs"
    ],
    "removes_by_default": [
      "bin",
      "venv",
      "mcp-venv",
      "open-webui-venv",
      "local-tools",
      "npm-global",
      "lmstudio",
      "nymph-agent.py"
    ]
  },
  "dependencies": {
    "python": "3.10+ or 3.11",
    "node": "20.19.0 local bootstrap when needed",
    "llama_cpp": "built locally with CUDA support",
    "lm_studio": "used for model download and management",
    "open_webui": "installed into local venv",
    "mcp": "mcp-proxy and mcpo installed into local venv"
  },
  "notes": [
    "Brain is an installer module, not a runtime dump.",
    "Open WebUI is exposed through the Manager local_url path.",
    "Manage Models keeps the installed lms-model terminal flow.",
    "Do not commit local models, venvs, Open WebUI databases, logs, secrets, or built llama-server binaries."
  ]
}
